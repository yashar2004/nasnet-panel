{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/out-tsc",
    "types": ["vitest/globals", "node"],
    "composite": false,
    "declaration": false
  },
  "include": [
    "vitest.setup.ts",
